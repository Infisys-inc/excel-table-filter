{
  "name": "excel-table-filter",
  "version": "1.0.0",
  "description": "Vanilla JS plugin to generate a checkbox drop-down table-filter",
  "author": {
    "name": "INFISYS INC",
    "email": "corp@infisys.net"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/excel-table-filter-bundle.js",
  "types": "dist/types/ExcelTableFilter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/ExcelTableFilter.d.ts",
      "default": "./dist/excel-table-filter-bundle.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Infisys-inc/excel-table-filter.git"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c && npm run copy:assets",
    "copy:assets": "cpx \"src/*.{html,css}\" dist",
    "typecheck": "tsc --noEmit",
    "deps:check": "npm outdated",
    "deps:update": "npx npm-check-updates -u && npm install",
    "verify": "npm run typecheck && npm run build",
    "prepack": "npm run verify"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "cpx2": "^8.0.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
